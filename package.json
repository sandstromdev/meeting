{
	"name": "@lsnd-meeting/meeting-tools",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.3.8",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"build:vercel": "turbo run build --filter=@lsnd-meeting/web",
		"check": "turbo run check",
		"check:watch": "turbo run check:watch --filter=@lsnd-meeting/web",
		"clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules && bun install",
		"dev": "turbo run dev --parallel",
		"dev:all": "turbo run dev --parallel",
		"dev:convex": "turbo run dev --filter=@lsnd-meeting/convex",
		"dev:vite": "turbo run dev --filter=@lsnd-meeting/web",
		"env:validate": "turbo run env:validate --filter=@lsnd-meeting/web",
		"env:validate:convex": "turbo run env:validate --filter=@lsnd-meeting/convex",
		"env:validate:all": "turbo run env:validate",
		"env:convex": "turbo run validate:convex-env --filter=@lsnd-meeting/convex",
		"env:convex:prod": "turbo run validate:convex-env:prod --filter=@lsnd-meeting/convex",
		"fix": "prettier --cache --write . && oxlint --fix .",
		"format": "prettier --cache --write .",
		"lint": "turbo run lint",
		"prepare": "husky",
		"preview": "turbo run preview --filter=@lsnd-meeting/web",
		"test": "turbo run test",
		"test:watch": "turbo run test:watch --filter=@lsnd-meeting/web"
	},
	"devDependencies": {
		"@edge-runtime/vm": "^5.0.0",
		"@eslint/compat": "^2.0.5",
		"@lucide/svelte": "^1.8.0",
		"@svelte-put/qr": "^2.1.2",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.6.0",
		"@vitest/ui": "4.1.4",
		"concurrently": "^9.2.1",
		"convex-helpers": "^0.1.114",
		"convex-test": "^0.0.48",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"ora": "^9.3.0",
		"oxlint": "^1.59.0",
		"oxlint-tsgolint": "^0.20.0",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"turbo": "^2.9.6",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"varlock": "^0.7.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@convex-dev/better-auth": "^0.11.4",
		"@convex-dev/migrations": "^0.3.3",
		"@fontsource-variable/nunito": "^5.2.7",
		"@internationalized/date": "^3.12.0",
		"@mmailaender/convex-better-auth-svelte": "^0.7.3",
		"@mmailaender/convex-svelte": "^0.18.0",
		"@tanstack/table-core": "^8.21.3",
		"better-auth": "1.5.5",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"convex": "^1.35.1",
		"formsnap": "^2.0.1",
		"isomorphic-dompurify": "^3.8.0",
		"marked": "^18.0.0",
		"mode-watcher": "^1.1.0",
		"runed": "^0.37.1",
		"svelte-sonner": "^1.1.0",
		"svelte-toolbelt": "^0.10.6",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"zod": "^4.3.6"
	},
	"lint-staged": {
		"*.{js,ts,svelte,mjs,cjs,json,css,md}": [
			"prettier --write",
			"oxlint --fix"
		]
	}
}

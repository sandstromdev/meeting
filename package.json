{
	"name": "@lsnd/meeting-tools",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.3.8",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"bootstrap": "bun install --frozen-lockfile",
		"dev": "turbo run dev",
		"build": "turbo run build",
		"test": "turbo run test",
		"lint": "turbo run lint",
		"check": "turbo run check",
		"env:validate": "turbo run env:validate",
		"env:load": "turbo run env:load",
		"clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules && bun install",
		"prepare": "husky",
		"format": "prettier --cache --write .",
		"fix": "prettier --cache --write . && oxlint --fix ."
	},
	"devDependencies": {
		"@types/bun": "^1.3.12",
		"@types/node": "^25.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"oxlint": "^1.59.0",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"turbo": "^2.5.4"
	},
	"lint-staged": {
		"*.{js,ts,svelte,mjs,cjs,json,css,md}": [
			"prettier --write",
			"oxlint --fix"
		]
	}
}

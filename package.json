{
	"name": "@lsnd/meeting-tools",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"build": "varlock run -- vite build",
		"build:vercel": "convex deploy --cmd-url-env-var-name PUBLIC_CONVEX_URL --cmd \"bun run build\"",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"clean": "rm -rf node_modules && bun install",
		"dev:all": "varlock run -- conc \"bun run dev:vite\" \"bun run dev:convex\"",
		"dev:convex": "convex dev",
		"dev:vite": "varlock run -- vite dev --port 4000 --host",
		"env:validate": "varlock load",
		"fix": "prettier --cache --write . && oxlint --fix .",
		"format": "prettier --cache --write .",
		"lint": "prettier --cache --check . && oxlint .",
		"prepare": "svelte-kit sync || echo '' && husky",
		"preview": "varlock run -- vite preview",
		"test": "varlock run -- vitest run",
		"test:watch": "varlock run -- vitest"
	},
	"devDependencies": {
		"@edge-runtime/vm": "^5.0.0",
		"@eslint/compat": "^2.0.3",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.0.1",
		"@svelte-put/qr": "^2.1.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^25.5.0",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"convex-helpers": "^0.1.114",
		"convex-test": "^0.0.43",
		"eslint": "^10.1.0",
		"eslint-plugin-svelte": "^3.16.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"mode-watcher": "^1.1.0",
		"oxlint-tsgolint": "^0.17.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.2",
		"vitest": "^4.1.1"
	},
	"dependencies": {
		"@convex-dev/better-auth": "^0.11.3",
		"@fontsource-variable/nunito": "^5.2.7",
		"@mmailaender/convex-better-auth-svelte": "^0.7.1",
		"@mmailaender/convex-svelte": "^0.18.0",
		"better-auth": "1.5.5",
		"convex": "^1.34.0",
		"oxlint": "^1.56.0",
		"runed": "^0.37.1",
		"varlock": "^0.6.3",
		"zod": "^4.3.6"
	},
	"lint-staged": {
		"*.{js,ts,svelte,mjs,cjs,json,css,md}": [
			"prettier --write",
			"oxlint --fix"
		]
	}
}

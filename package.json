{
	"name": "@lsnd/meeting-tools",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"build": "bun run env:validate && vite build",
		"build:vercel": "convex deploy --cmd-url-env-var-name PUBLIC_CONVEX_URL --cmd \"bun run build\"",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"clean": "rm -rf node_modules && bun install",
		"dev:all": "conc \"bun run dev:vite\" \"bun run dev:convex\"",
		"dev:convex": "convex dev",
		"dev:vite": "bun run env:validate && vite dev --port 4000 --host",
		"env:validate": "varlock load",
		"env:convex": "bun run scripts/validate-convex-env.ts",
		"env:convex:prod": "bun run scripts/validate-convex-env.ts --prod",
		"fix": "prettier --cache --write . && oxlint --fix .",
		"format": "prettier --cache --write .",
		"lint": "prettier --cache --check . && oxlint .",
		"prepare": "svelte-kit sync || echo '' && husky",
		"preview": "bun run env:validate && vite preview",
		"test": "bun run env:validate && vitest run",
		"test:watch": "bun run env:validate && vitest"
	},
	"devDependencies": {
		"@edge-runtime/vm": "^5.0.0",
		"@eslint/compat": "^2.0.5",
		"@lucide/svelte": "^1.8.0",
		"@svelte-put/qr": "^2.1.2",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.6.0",
		"@vitest/ui": "4.1.4",
		"concurrently": "^9.2.1",
		"convex-helpers": "^0.1.114",
		"convex-test": "^0.0.47",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"ora": "^9.3.0",
		"oxlint": "^1.59.0",
		"oxlint-tsgolint": "^0.20.0",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.1",
		"varlock": "^0.7.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@convex-dev/better-auth": "^0.11.4",
		"@convex-dev/migrations": "^0.3.3",
		"@fontsource-variable/nunito": "^5.2.7",
		"@internationalized/date": "^3.12.0",
		"@mmailaender/convex-better-auth-svelte": "^0.7.3",
		"@mmailaender/convex-svelte": "^0.18.0",
		"@tanstack/table-core": "^8.21.3",
		"better-auth": "1.5.5",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"convex": "^1.35.1",
		"formsnap": "^2.0.1",
		"isomorphic-dompurify": "^3.8.0",
		"marked": "^18.0.0",
		"mode-watcher": "^1.1.0",
		"runed": "^0.37.1",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"zod": "^4.3.6"
	},
	"lint-staged": {
		"*.{js,ts,svelte,mjs,cjs,json,css,md}": [
			"prettier --write",
			"oxlint --fix"
		]
	}
}

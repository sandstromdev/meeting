{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".svelte-kit/**", "build/**", ".vercel/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"check": {
			"dependsOn": ["^build"]
		},
		"lint": {},
		"env:validate": {
			"cache": false
		},
		"env:load": {
			"cache": false
		},
		"prepare": {
			"cache": false
		}
	}
}

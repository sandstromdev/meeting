{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["build/**", ".svelte-kit/**"]
		},
		"check": {
			"dependsOn": ["^check"],
			"outputs": []
		},
		"check:watch": {
			"cache": false,
			"persistent": true
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^lint"],
			"outputs": []
		},
		"preview": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^test"],
			"outputs": []
		},
		"test:watch": {
			"cache": false,
			"persistent": true
		},
		"env:validate": {
			"cache": false,
			"outputs": []
		},
		"validate:convex-env": {
			"cache": false,
			"outputs": []
		},
		"validate:convex-env:prod": {
			"cache": false,
			"outputs": []
		}
	}
}

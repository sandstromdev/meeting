{
	"name": "@lsnd-meeting/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"env:validate": "bun run scripts/env-validate.ts",
		"build": "bun run env:validate -- --no-output && vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "bun run env:validate -- --no-output && vite dev --port 4000 --host",
		"lint": "prettier --cache --check . --ignore-path ../../.prettierignore && oxlint .",
		"preview": "bun run env:validate -- --no-output && vite preview",
		"test": "bun run env:validate -- --no-output && vitest run",
		"test:watch": "bun run env:validate -- --no-output && vitest"
	},
	"dependencies": {
		"@fontsource-variable/nunito": "^5.2.7",
		"@internationalized/date": "^3.12.0",
		"@lsnd-meeting/convex": "workspace:*",
		"@lucide/svelte": "^1.8.0",
		"@mmailaender/convex-better-auth-svelte": "^0.7.3",
		"@mmailaender/convex-svelte": "^0.18.0",
		"@tanstack/table-core": "^8.21.3",
		"better-auth": "1.5.5",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"convex": "^1.35.1",
		"formsnap": "^2.0.1",
		"isomorphic-dompurify": "^3.8.0",
		"marked": "^18.0.0",
		"mode-watcher": "^1.1.0",
		"runed": "^0.37.1",
		"svelte-sonner": "^1.1.0",
		"svelte-toolbelt": "^0.10.6",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@svelte-put/qr": "^2.1.2",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.6.0",
		"@vitest/ui": "4.1.4",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	}
}
